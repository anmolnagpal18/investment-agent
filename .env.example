# ==============================================================================
# InvestIQ - Backend Environment Template
# Copy this file to 'backend/.env' and fill in your keys.
# ==============================================================================

# Set to True for local development, False for production
DEBUG=True

# Django Secret Key (generate a secure random string for production)
SECRET_KEY=django-insecure-local-development-key-change-this-for-production

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite database URL (default)
DATABASE_URL=sqlite:///db.sqlite3

# Production Postgres Database URL (e.g. Neon.tech)
# DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Google Gemini AI API Key (Required for research agent scoring & summaries)
GEMINI_API_KEY=your_google_gemini_api_key_here
